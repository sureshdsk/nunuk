# Copy to `.env` and fill in. `.env` is gitignored.

# Required for module 01+. Get one at https://openrouter.ai.
OPENROUTER_API_KEY=

# Default model used by the agent. Override per shell or per-run as needed.
MODEL=z-ai/glm-4.5-air:free

# Set by the runner during tests; you do not normally set these by hand.
# LLM_PROVIDER=mock
# MOCK_LLM_BASE_URL=http://127.0.0.1:8080
